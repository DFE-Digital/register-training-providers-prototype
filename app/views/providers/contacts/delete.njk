{% extends "layouts/main.njk" %}

{% set primaryNavId = "providers" %}
{% set secondaryNavId = "contacts" %}

{% block pageTitle -%}
  Confirm you want to delete provider contact{% if isSupportUser %} - {{ provider.operatingName }}{% endif %} - {{ serviceName }} - GOV.UK
{%- endblock %}

{% set title = "Confirm you want to delete " + contact.firstName + " " + contact.lastName %}
{% if isSupportUser %}
  {% set caption = "Delete contact - " + provider.operatingName %}
{% else %}
  {% set caption = "Delete contact" %}
{% endif %}

{% block beforeContent %}
{{ govukBackLink({
  text: "Back",
  href: actions.back
}) }}
{% endblock %}

{% block content %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    {% include "_includes/page-heading.njk" %}

    <form action="{{ actions.delete }}" method="post" accept-charset="utf-8" novalidate>

      {{ govukSummaryList({
        rows: [
          {
            key: {
              text: "First name"
            },
            value: {
              text: contact.firstName
            }
          },
          {
            key: {
              text: "Last name"
            },
            value: {
              text: contact.lastName
            }
          },
          {
            key: {
              text: "Email address"
            },
            value: {
              text: contact.email if contact.email.length else "Not entered",
              classes: "govuk-hint" if not contact.email.length
            }
          },
          {
            key: {
              text: "Phone number"
            },
            value: {
              text: contact.telephone if contact.telephone.length else "Not entered",
              classes: "govuk-hint" if not contact.telephone.length
            }
          }
        ]
      }) }}

      {{ govukWarningText({
        text: "Deleting a contact is permanent – you cannot undo it.",
        iconFallbackText: "Warning"
      }) }}

      {{ govukButton({
        text: "Delete contact",
        classes: "govuk-button--warning"
      }) }}

    </form>

    <p class="govuk-body">
      <a class="govuk-link" href="{{ actions.cancel }}">Cancel</a>
    </p>

  </div>
</div>

{% endblock %}
